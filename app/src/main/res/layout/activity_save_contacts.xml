<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾  Save Unsaved Numbers"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingTop="16dp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/tvCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="14sp"
            android:paddingBottom="20dp" />

        <!-- Base name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Contact base name:"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/etBaseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g.  Client   or   Old Client   or   Lead"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface_dark"
            android:padding="14dp"
            android:textSize="15sp"
            android:inputType="textCapWords"
            android:layout_marginBottom="12dp" />

        <!-- Start index -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start number from:"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:paddingBottom="6dp" />

        <EditText
            android:id="@+id/etStartIndex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1"
            android:text="1"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@color/surface_dark"
            android:padding="14dp"
            android:textSize="15sp"
            android:inputType="number"
            android:layout_marginBottom="6dp" />

        <!-- Live preview -->
        <TextView
            android:id="@+id/tvPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:paddingBottom="20dp" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressSave"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:indeterminate="false"
            android:progressTint="@color/accent_green"
            android:progressBackgroundTint="@color/surface_dark"
            android:visibility="gone"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvSaveProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnStartSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="💾  Start Saving"
            style="@style/GreenButton" />

        <Button
            android:id="@+id/btnCancelSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel"
            style="@style/OutlineButton" />

    </LinearLayout>
</ScrollView>
